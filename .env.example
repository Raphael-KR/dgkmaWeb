# 카카오 로그인 설정

# Replit 내장 PostgreSQL (PG* 환경변수 자동 주입)
# Replit 환경에서는 PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE 가 자동으로 주입됩니다.
# 별도 DATABASE_URL 설정 없이 Drizzle이 PG* 변수로 직접 접속합니다.
# 로컬 개발 시에만 필요한 경우 아래에 직접 설정하세요.
# DATABASE_URL=postgresql://user:password@host:port/database

# 구글 시트 API (동문 데이터 연동용)
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Sheets API credentials (service account)
GOOGLE_SHEETS_PRIVATE_KEY=""
GOOGLE_SHEETS_CLIENT_EMAIL=""
GOOGLE_SHEETS_SPREADSHEET_ID=""

# 카카오톡 메시지 API (알림용)
KAKAO_ADMIN_KEY=your_kakao_admin_key_here

# Kakao Login (server-side)
KAKAO_REST_API_KEY=""
KAKAO_CLIENT_SECRET=""

# Kakao Login (client-side)
VITE_KAKAO_JAVASCRIPT_KEY=""

# JWT 비밀키
JWT_SECRET=your_jwt_secret_key_here

# 개발 환경 설정
NODE_ENV=development
