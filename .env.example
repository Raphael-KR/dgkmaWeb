# 카카오 로그인 설정

# Replit 내장 PostgreSQL (PG* 환경변수 자동 주입)
# Replit 환경에서는 PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE 가 자동으로 주입됩니다.
# 별도 DATABASE_URL 설정 없이 Drizzle이 PG* 변수로 직접 접속합니다.
# 로컬 개발 시에만 필요한 경우 아래에 직접 설정하세요.
# DATABASE_URL=postgresql://user:password@host:port/database

# 구글 시트 API (동문 데이터 연동용)
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Sheets API credentials (service account)
GOOGLE_SHEETS_PRIVATE_KEY=""
GOOGLE_SHEETS_CLIENT_EMAIL=""
GOOGLE_SHEETS_SPREADSHEET_ID=""

# 카카오톡 메시지 API (알림용)
KAKAO_ADMIN_KEY=your_kakao_admin_key_here

# Kakao Login (server-side)
# ⚠️ KAKAO_REST_API_KEY 는 카카오 디벨로퍼스 [앱 설정 > 앱 키 > REST API 키] 값.
#   프론트의 VITE_KAKAO_JAVASCRIPT_KEY (JavaScript 키) 와는 같은 앱이라도 값이 다름.
#   (카카오는 플랫폼별로 다른 키를 발급 — JS 키, REST 키, Native 키, Admin 키.)
#   서버 로그의 [Kakao OAuth] token body debug 의 clientIdPrefix 6자리가
#   콘솔 REST API 키 앞 6자리와 일치하는지 항상 확인.
#   같은 TEST 앱인지 확인하려면 같은 앱 카드 안에서 JS 키와 REST 키를 함께 비교.
KAKAO_REST_API_KEY=""
# ⚠️ "카카오 로그인" 용 클라이언트 시크릿만 사용 (콘솔 [카카오 로그인 > 보안] 메뉴).
#   비즈니스 인증용 클라이언트 시크릿은 사용하지 않음.
#   콘솔에서 시크릿이 활성화 상태일 때만 필수, 비활성이면 비워둘 것.
KAKAO_CLIENT_SECRET=""
# 카카오 디벨로퍼스 콘솔 [카카오 로그인 > Redirect URI] 등록값과 byte-for-byte 동일해야 함
# (KOE303 / KOE114 회피). 미설정 시 Origin/Referer 헤더 기반 fallback.
KAKAO_REDIRECT_URI="https://dgkma.replit.app/kakao-callback"

# 배포 도메인 (KAKAO_REDIRECT_URI 미설정 + Origin/Referer 헤더 결손 시 fallback)
APP_URL="https://dgkma.replit.app"

# Kakao Login (client-side)
VITE_KAKAO_JAVASCRIPT_KEY=""

# JWT 비밀키
JWT_SECRET=your_jwt_secret_key_here

# 개발 환경 설정
NODE_ENV=development
