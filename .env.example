# 카카오 로그인 설정

# Replit 내장 PostgreSQL (PG* 환경변수 자동 주입)
# Replit 환경에서는 PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE 가 자동으로 주입됩니다.
# 별도 DATABASE_URL 설정 없이 Drizzle이 PG* 변수로 직접 접속합니다.
# 로컬 개발 시에만 필요한 경우 아래에 직접 설정하세요.
# DATABASE_URL=postgresql://user:password@host:port/database

# 구글 시트 API (동문 데이터 연동용)
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Sheets API credentials (service account)
GOOGLE_SHEETS_PRIVATE_KEY=""
GOOGLE_SHEETS_CLIENT_EMAIL=""
GOOGLE_SHEETS_SPREADSHEET_ID=""

# 카카오톡 메시지 API (알림용)
KAKAO_ADMIN_KEY=your_kakao_admin_key_here

# Kakao Login (server-side)
#
# ⚠️ 같은 카카오 앱이라도 키는 플랫폼별로 다른 값입니다.
#   카카오 디벨로퍼스 [앱 설정 > 앱 키] 화면 한 카드(같은 TEST 앱) 안에서
#   네이티브 / REST / JavaScript / Admin 4종이 함께 표시되며, 각각 값이 다릅니다.
#
#   - KAKAO_REST_API_KEY        = 같은 TEST 앱의 "REST API 키"
#   - VITE_KAKAO_JAVASCRIPT_KEY = 같은 TEST 앱의 "JavaScript 키" (프론트 SDK용)
#   두 값은 서로 다르지만, 카카오 콘솔의 동일 앱 카드의 앱 키 목록에서
#   함께 나온 값이어야 합니다 (다른 앱의 키를 섞어 쓰면 KOE114).
#
#   ★ 서버 token exchange 에는 반드시 KAKAO_REST_API_KEY 만 사용합니다.
#     KAKAO_CLIENT_ID / VITE_KAKAO_REST_API_KEY / KAKAO_ADMIN_KEY 등
#     다른 env 로 fallback 하지 않습니다. (VITE_KAKAO_JAVASCRIPT_KEY 도 ❌)
#
#   ★ 검증 방법: 서버 부팅 로그의
#       [Kakao OAuth] env check: { restApiKeyPrefix: '...' }
#     prefix 6자리가 카카오 콘솔의 REST API 키 앞 6자리와 일치하는지 확인.
#     불일치하면 Replit Secrets 의 KAKAO_REST_API_KEY 값이 잘못 설정된 것.
KAKAO_REST_API_KEY=""

# ⚠️ "카카오 로그인" 용 클라이언트 시크릿만 사용 (콘솔 [카카오 로그인 > 보안] 메뉴).
#   비즈니스 인증용 클라이언트 시크릿은 사용하지 않음.
#   콘솔에서 시크릿이 활성화 상태일 때만 필수, 비활성이면 비워둘 것.
KAKAO_CLIENT_SECRET=""

# 카카오 디벨로퍼스 콘솔 [카카오 로그인 > Redirect URI] 등록값과 byte-for-byte 동일해야 함
# (KOE303 / KOE114 회피). 미설정 시 Origin/Referer 헤더 기반 fallback.
KAKAO_REDIRECT_URI="https://dgkma.replit.app/kakao-callback"

# 배포 도메인 (KAKAO_REDIRECT_URI 미설정 + Origin/Referer 헤더 결손 시 fallback)
APP_URL="https://dgkma.replit.app"

# Kakao Login (client-side)
VITE_KAKAO_JAVASCRIPT_KEY=""

# JWT 비밀키
JWT_SECRET=your_jwt_secret_key_here

# 개발 환경 설정
NODE_ENV=development
